# ─── PPDM39 MetaBrowser — Docker Environment Template ────────────────────────
# Copy file ini ke .env dan sesuaikan nilainya sebelum `docker compose up`

# ─── Meta DB (ppdm_meta) ──────────────────────────────────────────────────────
META_DB_NAME=ppdm_meta
META_DB_USER=postgres
META_DB_PASS=changeme_strong_password
META_DB_SCHEMA=public

# ─── Target DB (opsional, untuk fitur Audit) ──────────────────────────────────
TARGET_DB_ENABLED=false
TARGET_DB_HOST=
TARGET_DB_PORT=5432
TARGET_DB_NAME=
TARGET_DB_USER=
TARGET_DB_PASS=
TARGET_DB_SCHEMA=public

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Set true hanya pada deploy PERTAMA untuk mengisi skema PPDM 3.9 dari GitHub.
# Setelah seed berhasil, ubah ke false agar tidak re-seed setiap restart.
SEED_ON_START=true

# ─── Port yang diekspos ke host ───────────────────────────────────────────────
API_PORT=3001
FRONTEND_PORT=80
